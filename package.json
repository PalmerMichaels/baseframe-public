{
  "name": "baseframe",
  "version": "0.1.0",
  "description": "Synthetic launch operating-frame CLI for clean-room public demos.",
  "type": "module",
  "private": false,
  "bin": {
    "baseframe": "./src/cli.ts"
  },
  "scripts": {
